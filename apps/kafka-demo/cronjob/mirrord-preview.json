{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "namespace": "kafka-demo",
    "path": {
      "cron_job": "cronjob-z"
    }
  },
  "feature": {
    "copy_target": true,
    "network": {
      "outgoing": true
    },
    "db_branches": [
      {
        "type": "pg",
        "version": "16",
        "name": "kafkademo",
        "ttl_secs": 300,
        "connection": {
          "url": {
            "type": "env",
            "variable": "DATABASE_URL"
          }
        },
        "copy": {
          "mode": "schema"
        }
      }
    ]
  }
}
