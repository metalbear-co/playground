{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "path": "cronjob/cronjob-z/container/main",
    "namespace": "kafka-demo-event"

  },  
    "feature": {
    "copy_target": true,
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      },
      "outgoing":true
    },"db_branches": [
    {
      "type": "pg",
      "ttl_secs": 30,    
      "version": "16.0",
      "connection": {
        "url": "DATABASE_URL"
      },
      "copy": {
        "mode": "schema"                 
      }
    }
   ]
  }
}
