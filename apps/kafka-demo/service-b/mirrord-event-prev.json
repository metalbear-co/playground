{
  "key": "changed-responce",
  "target": {
    "namespace": "kafka-demo-event",
    "path": {
      "deployment": "service-b-ev"
    }
  },
  "feature": {
    "preview": {
      "image": "ghcr.io/metalbear-co/playground-kafka-demo-service-b:latest",
      "ttl_mins": 120,
      "creation_timeout_secs": 600
    },
    "network": {
      "outgoing": true
    },
    "split_queues": {
      "relay": {
        "queue_type": "Kafka",
        "message_filter": {
          "baggage": ".*mirrord-session={{key}}.*"
        }
      }
    },
     "db_branches": [
      {
        "type": "pg",
        "version": "16",
        "ttl_secs": 300,
        "connection": {
          "url": {
            "type": "env",
            "variable": "DATABASE_URL"
          }
        },
        "copy": {
          "mode": "schema"
        }
      }
    ]
  }
}
