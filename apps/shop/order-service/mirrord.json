{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "order-service"
    }
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      }
    },
    "db_branches": [
    {
      "id": "{{key}}-order-db",
      "type": "pg",
      "ttl_secs": 30,    
      "version": "16.0",
      "connection": {
        "url": {
          "type": "env",
          "variable": "DATABASE_URL"
        }
      },
      "copy": {
        "mode": "schema"                 
      }
    }
  ]
  }
}