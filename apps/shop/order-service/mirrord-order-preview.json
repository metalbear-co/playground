{
  "key":"preview-123",
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "order-service"
    }
  },
  "feature": {
    "fs": "read",
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord={{key}}\\b"
        }
      },
      "outgoing":true
    },"db_branches": [
    {
      "id": "{{key}}",
      "type": "pg",
      "ttl_secs": 30,    
      "version": "16.0",
      "connection": {
        "url": {
          "type": "env",
          "variable": "DATABASE_URL"
        }
      },
      "copy": {
        "mode": "schema"                 
      }
    }
  ],
  "preview": {
      "image": "ghcr.io/metalbear-co/playground/order-service:latest",
      "ttl_mins": 60,
      "creation_timeout_secs": 60
    }
  
  },
  "internal_proxy": {
    "log_destination": "/tmp/mirrord.log",
    "log_level": "mirrord=trace"
  }
}
