{
  "key":"ari",
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "delivery-service"
    }
  },
  "feature": {
    "network": {
      "outgoing": true
    },
    "split_queues": {
      "orders": {
        "queue_type": "Kafka",
        "message_filter": {
          "baggage": "^mirrord={{key}}$"
        }
      }
    }
  }
}
