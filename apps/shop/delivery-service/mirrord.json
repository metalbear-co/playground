{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "path": {
      "deployment": "delivery-service"
    }
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      }
    },
    "split_queues": {
      "orders": {
        "queue_type": "Kafka",
        "message_filter": {
          "baggage": "^mirrord-session={{key}}$"
        }
      }
    }
  }
}
