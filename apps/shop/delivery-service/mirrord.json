{
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "delivery-service"
    }
  },
  "feature": {
    "env": {
      "override": {
        "KAFKA_CONSUMER_GROUP": "delivery-service-local"
      }
    },
    "network": {
      "incoming": "steal",
      "outgoing": true
    },
    "split_queues": {
      "orders": {
        "queue_type": "Kafka",
        "message_filter": {
          "x-pg-tenant": "dev"
        }
      }
    }
  }
}
