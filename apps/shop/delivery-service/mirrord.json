{
  "key": "{{ get_env(name='USER', default='changeme') }}",
   "target": {
    "namespace": "shop",
    "path": {
      "deployment": "delivery-service"
    }
  },
  "feature": {
    "network": {
      "incoming": "steal",
      "outgoing": true
    },
    "split_queues": {
      "orders": {
        "queue_type": "Kafka",
        "message_filter": {
          "baggage": ".*mirrord-session={{key}}.*"
        }
      }
    }
  }
}
