{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "path": "deploy/inventory-service",
    "namespace": "shop"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      },
    "db_branches": [
      {
        "id": "{{key}}-inventory-db",
        "type": "pg",
        "ttl_secs": 30,
        "version": "16.0",
        "connection": {
          "url": "DATABASE_URL"
        },
        "copy": {
          "mode": "all"
        }
      }
    ]
    }
  }
}
