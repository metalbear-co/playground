{
  "key": "ari",
  "target": {
    "path": "deploy/inventory-service",
    "namespace": "shop"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord={{key}}\\b"
        }
      }
    }, 
    "preview": {
      "image": "ghcr.io/metalbear-co/playground-inventory-service:latest",
      "ttl_mins": 10,
      "creation_timeout_secs": 600
    },
    "db_branches": [
      {
        "id": "{{key}}01-branch-db",
        "type": "pg",
        "ttl_secs": 30,
        "version": "16.0",
        "connection": {
          "url": "DATABASE_URL"
        },
        "copy": {
          "mode": "schema"
        }
      }
    ]
  }
}