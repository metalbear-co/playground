{
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "receipt-service"
    }
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      }
    }
  }
}
