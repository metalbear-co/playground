{
  "target": {
    "namespace": "visualization-shop",
    "path": {
      "deployment": "visualization-shop-backend"
    }
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord=ari\\b"
        }
      },
      "outgoing": true
    }
  },
  "internal_proxy": {
    "log_destination": "/tmp/mirrord.log",
    "log_level": "mirrord=trace"
  }

}
