{
  "key": "kiran",
  "target": {
    "path": "deployment/equipment-query",
    "namespace": "minerva"
  },
  "feature": {
    "env": {
      "include": "*"
    },
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        },
        "port_mapping": [[8085, 8080]]
      },
      "outgoing": true
    }
  }
}