{
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "order-service"
    }
  },
  "ci": {
    "output_dir": "/tmp/mirrord"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session=mirrord-ci-shop\\b"
        }
      },
      "outgoing": true
    },
    "fs": {
      "mode": "read"
    }
  }
}
