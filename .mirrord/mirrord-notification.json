{
  "operator": true,
  "key": "{{ get_env(name='USER', default='changeme') }}",
  "target": {
    "namespace": "shop",
    "path": {
      "deployment": "notifications-service"
    }
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord-session={{key}}\\b"
        }
      },
      "outgoing": true
    },
    "split_queues": {
      "order-notifications": {
        "queue_type": "RMQ",
        "message_filter": {
          "baggage": ".*mirrord-session={{key}}.*"
        }
      }
    }
  }
}
